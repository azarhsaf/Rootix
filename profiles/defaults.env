# Versioned defaults for Offline Root CA wizard.
PROFILE_VERSION="1.0"
DEFAULT_COUNTRY="US"
DEFAULT_ROOT_VALIDITY_DAYS="7300"
DEFAULT_ISSUING_VALIDITY_DAYS="3650"
DEFAULT_CRL_NEXT_DAYS="30"
DEFAULT_M_OF_N_M="2"
DEFAULT_M_OF_N_N="3"

# Optional policy OID to include in certificates. Leave empty to disable.
POLICY_OID="1.3.6.1.4.1.55555.1.1"

# strict subject policy behavior for openssl ca flows
POLICY_STRICT="yes"
